generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id          String   @id @default(cuid())
  customer    String
  email       String
  phone       String
  address     String
  city        String
  pincode     String

  products    Json

  totalAmount Int

  paymentId   String?

  createdAt   DateTime @default(now())
}